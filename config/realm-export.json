{
  "realm": "operix-service",
  "enabled": true,
  "displayName": "Operix Service",
  "displayNameHtml": "<b>Operix</b> Service",
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "defaultRoles": [
    "offline_access",
    "uma_authorization"
  ],
  "roles": {
    "realm": [
      { "name": "module:operational",    "description": "Acesso ao módulo de gestão operacional (serviços, OS, status, tipos de produto)", "composite": false },
      { "name": "module:inventory",      "description": "Acesso ao módulo de estoque", "composite": false },
      { "name": "module:notifications",  "description": "Acesso ao módulo de notificações e alertas", "composite": false },
      {
        "name": "role:beginner",
        "description": "Plano inicial",
        "composite": true,
        "composites": {
          "realm": ["module:operational", "module:organization"]
        }
      },
      {
        "name": "role:intermediate",
        "description": "Plano intermediário",
        "composite": true,
        "composites": {
          "realm": ["module:operational", "module:organization", "module:notifications"]
        }
      },
      {
        "name": "role:advanced",
        "description": "Plano completo",
        "composite": true,
        "composites": {
          "realm": ["module:operational", "module:organization", "module:notifications", "module:inventory"]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "operix-service-app",
      "enabled": true,
      "publicClient": true,
      "fullScopeAllowed": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:3333/*"],
      "webOrigins": ["http://localhost:3000", "http://localhost:3333"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "tenant_id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "user.attribute": "tenant_id",
            "jsonType.label": "int"
          }
        },
        {
          "name": "group-membership",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]

    }
  ],
  "keycloakVersion": "26.0.7"
}