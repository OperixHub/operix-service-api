{
  "name": "operix-service-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "database": "docker compose -f compose.yaml up -d --build",
    "database:down": "docker compose -f compose.yaml down -v",
    "docker:dev": "docker compose -f compose.yaml up -d --build",
    "docker:dev:down": "docker compose -f compose.yaml down -v",
    "docker:prod": "docker compose -f compose.prod.yaml up -d --build",
    "docker:prod:down": "docker compose -f compose.prod.yaml down -v",
    "migrate": "bunx sequelize-cli db:migrate",
    "seed": "bunx sequelize-cli db:seed:all",
    "dev": "bun run --watch src/core/server.ts",
    "start": "bun run src/core/server.ts",
    "test": "bun test tests",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "clean": "rm -rf dist && echo 'Done.'",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/core/server.ts --outdir ./dist --target bun",
    "start-from-build": "bun run dist/server.js",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "author": "João Pedro Pereira Lima",
  "license": "MIT",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "argon2": "^0.30.3",
    "aws-sdk": "^2.1693.0",
    "body-parser": "^1.20.4",
    "core-js": "^3.48.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "mock-aws-s3": "^4.0.2",
    "moment": "^2.30.1",
    "nock": "^14.0.11",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "zod-to-openapi": "^0.2.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "swagger-autogen": "^2.23.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
